{
  "title": "Grid Trading Bot Dashboard",
  "uid": "grid-trading-bot",
  "schemaVersion": 36,
  "refresh": "10s",
  "templating": {
    "list": [
      {
        "name": "trading_pair",
        "type": "query",
        "datasource": "Loki",
        "query": "label_values(trading_pair)",
        "refresh": 2,
        "includeAll": false,
        "current": {}
      },
      {
        "name": "trading_mode",
        "type": "query",
        "datasource": "Loki",
        "query": "label_values(trading_mode)",
        "refresh": 2,
        "includeAll": false,
        "current": {}
      },
      {
        "name": "strategy",
        "type": "query",
        "datasource": "Loki",
        "query": "label_values(strategy_type)",
        "refresh": 2,
        "includeAll": false,
        "current": {}
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Price & Orders",
      "type": "timeseries",
      "datasource": "Loki",
      "gridPos": { "h": 12, "w": 24, "x": 0, "y": 0 },
      "targets": [
        {
          "refId": "A",
          "expr": "last_over_time({job=\"grid_trading_bot\", trading_pair=\"$trading_pair\"} |~ \"LiveExchangeService|BacktestExchangeService\" |= \"current price\" | regexp \"current price: (?P<price>[\\\\d.]+)\" | unwrap price [$__auto])",
          "legendFormat": "Price"
        },
        {
          "refId": "B",
          "expr": "last_over_time({job=\"grid_trading_bot\", trading_pair=\"$trading_pair\"} |= \"OrderManager\" |= \"buy limit order\" | regexp \"at grid level (?P<price>[\\\\d.]+)\" | unwrap price [$__auto])",
          "legendFormat": "Buy Order"
        },
        {
          "refId": "C",
          "expr": "last_over_time({job=\"grid_trading_bot\", trading_pair=\"$trading_pair\"} |= \"OrderManager\" |= \"sell limit order\" | regexp \"at grid level (?P<price>[\\\\d.]+)\" | unwrap price [$__auto])",
          "legendFormat": "Sell Order"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 1,
            "pointSize": 5,
            "showPoints": "auto"
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Price" },
            "properties": [
              { "id": "custom.drawStyle", "value": "line" },
              { "id": "custom.lineWidth", "value": 2 },
              { "id": "custom.showPoints", "value": "never" }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Buy Order" },
            "properties": [
              { "id": "custom.drawStyle", "value": "points" },
              { "id": "custom.pointSize", "value": 8 },
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "green" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Sell Order" },
            "properties": [
              { "id": "custom.drawStyle", "value": "points" },
              { "id": "custom.pointSize", "value": 8 },
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } }
            ]
          }
        ]
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      }
    },
    {
      "id": 2,
      "title": "Balance History",
      "type": "timeseries",
      "datasource": "Loki",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 12 },
      "targets": [
        {
          "refId": "A",
          "expr": "last_over_time({job=\"grid_trading_bot\", trading_pair=\"$trading_pair\"} |= \"BalanceTracker\" |= \"Updated balances\" | regexp \"Fiat balance: (?P<fiat>[\\\\d.]+)\" | unwrap fiat [$__auto])",
          "legendFormat": "Fiat ($trading_pair quote)"
        },
        {
          "refId": "B",
          "expr": "last_over_time({job=\"grid_trading_bot\", trading_pair=\"$trading_pair\"} |= \"BalanceTracker\" |= \"Updated balances\" | regexp \"Crypto balance: (?P<crypto>[\\\\d.]+)\" | unwrap crypto [$__auto])",
          "legendFormat": "Crypto ($trading_pair base)"
        },
        {
          "refId": "C",
          "expr": "last_over_time({job=\"grid_trading_bot\", trading_pair=\"$trading_pair\"} |= \"BalanceTracker\" |= \"Updated balances\" | regexp \"Total base balance: (?P<total_base>[\\\\d.]+)\" | unwrap total_base [$__auto])",
          "legendFormat": "Total ($trading_pair base)"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 10,
            "showPoints": "auto"
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byFrameRefID", "options": "A" },
            "properties": [
              { "id": "custom.axisPlacement", "value": "left" },
              { "id": "custom.axisLabel", "value": "Fiat" }
            ]
          },
          {
            "matcher": { "id": "byFrameRefID", "options": "B" },
            "properties": [
              { "id": "custom.axisPlacement", "value": "right" },
              { "id": "custom.axisLabel", "value": "Crypto" }
            ]
          },
          {
            "matcher": { "id": "byFrameRefID", "options": "C" },
            "properties": [
              { "id": "custom.axisPlacement", "value": "right" },
              { "id": "custom.axisLabel", "value": "Total (base)" },
              { "id": "custom.lineStyle", "value": { "fill": "dash", "dash": [10, 10] } },
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "yellow" } }
            ]
          }
        ]
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      }
    },
    {
      "id": 3,
      "title": "System Health (CPU %)",
      "type": "gauge",
      "datasource": "Loki",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 22 },
      "targets": [
        {
          "refId": "A",
          "expr": "last_over_time({job=\"grid_trading_bot\", trading_pair=\"$trading_pair\"} |= \"HealthCheck\" |= \"System resource usage\" | regexp \"'cpu': (?P<cpu>[\\\\d.]+)\" | unwrap cpu [$__auto])"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": 0, "color": "green" },
              { "value": 70, "color": "yellow" },
              { "value": 85, "color": "red" }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"]
        }
      }
    },
    {
      "id": 4,
      "title": "Strategy Overview",
      "type": "table",
      "datasource": "Loki",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 22 },
      "targets": [
        {
          "refId": "A",
          "expr": "{job=\"grid_trading_bot\", trading_pair=\"$trading_pair\", strategy_type=\"$strategy\", service=\"GridManager\"} |= \"Grids and levels initialized\" | line_format \"Grid Size: {{.grid_size}} | Range: {{.grid_range}} | Spacing: {{.spacing_type}} | Strategy: {{.strategy_type}}\"",
          "maxLines": 1
        }
      ],
      "options": {
        "showHeader": false,
        "cellHeight": "lg"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "blue" },
          "custom": {
            "align": "center",
            "cellOptions": { "type": "color-text" }
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Time" },
            "properties": [{ "id": "custom.hidden", "value": true }]
          },
          {
            "matcher": { "id": "byName", "options": "id" },
            "properties": [{ "id": "custom.hidden", "value": true }]
          },
          {
            "matcher": { "id": "byName", "options": "tsNs" },
            "properties": [{ "id": "custom.hidden", "value": true }]
          },
          {
            "matcher": { "id": "byName", "options": "labels" },
            "properties": [{ "id": "custom.hidden", "value": true }]
          }
        ]
      },
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "id": true,
              "tsNs": true,
              "labels": true
            }
          }
        }
      ]
    },
    {
      "id": 5,
      "title": "Executed Trades",
      "type": "stat",
      "datasource": "Loki",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 22 },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(count_over_time({job=\"grid_trading_bot\", trading_pair=\"$trading_pair\"} |= \"OrderManager\" |= \"Buy order completed at grid level\" [$__auto]))",
          "legendFormat": "Buy Fills"
        },
        {
          "refId": "B",
          "expr": "sum(count_over_time({job=\"grid_trading_bot\", trading_pair=\"$trading_pair\"} |= \"OrderManager\" |= \"Sell order completed at grid level\" [$__auto]))",
          "legendFormat": "Sell Fills"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": 0, "color": "text" },
              { "value": 1, "color": "green" }
            ]
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Buy Fills" },
            "properties": [
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "green" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Sell Fills" },
            "properties": [
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } }
            ]
          }
        ]
      },
      "options": {
        "reduceOptions": {
          "calcs": ["sum"]
        },
        "graphMode": "none",
        "colorMode": "value",
        "textMode": "value_and_name",
        "orientation": "horizontal"
      }
    }
  ]
}
